# OpenAI-compatible large model API configuration.
# BASE_URL examples:
# BASE_URL=https://api.openai.com/v1
# BASE_URL=https://your-provider.example.com/v1
# BASE_URL=https://your-provider.example.com/v1/chat/completions
BASE_URL=https://api.openai.com/v1
API_KEY=replace_with_your_api_key
MODEL=gpt-4o-mini

# Optional. Complex model architecture diagrams can take longer than simple flows.
# Value is in milliseconds and is clamped to 15000-300000.
LLM_REQUEST_TIMEOUT_MS=120000
